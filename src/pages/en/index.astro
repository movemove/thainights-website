---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${t('site.title')} - ${t('nav.home')}`} description={t('site.description')} />
		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: auto;
				padding: 3rem 1rem;
				color: #e0e0e0;
			}
			.hero {
				text-align: center;
				margin-bottom: 4rem;
			}
			.hero h1 {
				font-size: 3.5rem;
				color: var(--neon-blue);
				text-shadow: 0 0 20px var(--neon-blue);
				margin-bottom: 0.5rem;
			}
			.hero p {
				font-size: 1.2rem;
				color: var(--gray);
			}
			.card-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2rem;
			}
			.card {
				background: #16161a;
				padding: 1.5rem;
				border-radius: 12px;
				border: 1px solid #333;
				transition: all 0.3s ease;
				display: flex;
				flex-direction: column;
                text-decoration: none; /* Make entire card look non-link-like by default */
                cursor: pointer;
                position: relative;
			}
			.card:hover {
				transform: translateY(-5px);
				border-color: var(--neon-pink);
				box-shadow: 0 0 15px rgba(255, 0, 255, 0.2);
			}
			.card h3 {
				margin-top: 0;
				font-size: 1.5rem;
                transition: color 0.3s;
			}
            .card:hover h3 {
                color: var(--neon-pink);
            }
			.card p {
				flex: 1;
				color: var(--gray);
				font-size: 1rem;
				margin-bottom: 1.5rem;
			}
			.btn {
				background: var(--neon-pink);
				color: white;
				padding: 0.8rem 1.5rem;
				border-radius: 6px;
				text-decoration: none;
				display: inline-block;
				font-weight: bold;
				margin-top: 1rem;
				transition: opacity 0.2s;
			}
			.btn:hover {
				opacity: 0.9;
			}
			.read-more {
				color: var(--neon-pink);
				font-weight: bold;
				text-decoration: none;
				align-self: flex-start;
			}
            /* Use a pseudo-element to make the whole card clickable via the inner link */
            .card a.main-link::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
            }
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2.2rem;
				}
				.hero p {
					font-size: 1rem;
				}
				main {
					padding: 2rem 1rem;
				}
				.card-grid {
					gap: 1.5rem;
				}
			}
		</style>
	</head>
	<body style="background-color: #0a0a0c;">
		<Header />
		<main>
			<div class="hero">
				<h1>🇹🇭 ThaiNights</h1>
				<p>{t('site.description')}</p>
				<a href={lang === 'zh-tw' ? '/map' : `/${lang}/map`} class="btn">{t('nav.map')}</a>
			</div>
			
			<div class="card-grid">
				<div class="card">
					<h3>{t('index.nana.title')}</h3>
					<p>{t('index.nana.desc')}</p>
					<a href={lang === 'zh-tw' ? '/blog/nana-plaza' : `/${lang}/blog/nana-plaza`} class="read-more main-link">{t('index.read_more')}</a>
				</div>
				<div class="card">
					<h3>{t('index.cowboy.title')}</h3>
					<p>{t('index.cowboy.desc')}</p>
					<a href={lang === 'zh-tw' ? '/blog/soi-cowboy' : `/${lang}/blog/soi-cowboy`} class="read-more main-link">{t('index.read_more')}</a>
				</div>
				<div class="card">
					<h3>{t('index.pattaya.title')}</h3>
					<p>{t('index.pattaya.desc')}</p>
					<a href={lang === 'zh-tw' ? '/blog/pattaya-walking-street' : `/${lang}/blog/pattaya-walking-street`} class="read-more main-link">{t('index.read_more')}</a>
				</div>
				<div class="card">
					<h3>{t('index.massage.title')}</h3>
					<p>{t('index.massage.desc')}</p>
					<a href={lang === 'zh-tw' ? '/blog/massage-guide' : `/${lang}/blog/massage-guide`} class="read-more main-link">{t('index.read_more')}</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
