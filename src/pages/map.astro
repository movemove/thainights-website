---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`夜遊地圖 - ${SITE_TITLE}`} description="泰國夜生活互動地圖" />
		<style>
			main { width: 100%; max-width: 1000px; margin: 0 auto; padding: 2em 1em; color: #e0e0e0; }
			.map-container { height: 700px; border-radius: 12px; overflow: hidden; border: 1px solid #333; margin-top: 1rem; }
		</style>
	</head>
	<body style="background-color: #0a0a0c;">
		<Header />
		<main>
			<h1 style="color: var(--neon-blue);">🗺️ 泰國夜遊互動地圖</h1>
			<div class="map-container">
				<iframe width="100%" height="100%" frameborder="0" allowfullscreen src="https://umap.openstreetmap.fr/ja/map/thai-night-life_247238?scaleControl=false&miniMap=false&scrollWheelZoom=true&zoomControl=true&allowEdit=false&moreControl=true&searchControl=null&tilelayersControl=null&embedControl=null&datalayersControl=true&onLoadPanel=undefined&captionBar=false"></iframe>
			</div>
		</main>
		<Footer />
	</body>
</html>
