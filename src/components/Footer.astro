---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const today = new Date();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer>
    <div class="warning">
        {t('footer.warning')}
    </div>
	&copy; {today.getFullYear()} {t('footer.text')}
    <div class="version">
        v1.0.6-e44f136
    </div>
</footer>
<style>
	footer {
		padding: 4em 1rem;
		background: #0a0a0c;
		color: #666;
		text-align: center;
        border-top: 1px solid #222;
        font-size: 0.9rem;
	}
    .warning {
        color: #ff4444;
        font-weight: bold;
        margin-bottom: 1.5rem;
        font-size: 1rem;
        border: 1px solid #442222;
        padding: 10px;
        display: inline-block;
        border-radius: 8px;
        background: rgba(255, 68, 68, 0.05);
    }
    .version {
        margin-top: 15px;
        font-family: monospace;
        font-size: 0.7rem;
        opacity: 0.4;
    }
</style>
