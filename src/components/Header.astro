---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Improved URL matching for language switcher
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/^\/(en|zh-cn)(\/|$)/, '/');
---

<header>
	<nav>
		<h2><a href={lang === 'zh-tw' ? '/' : `/${lang}/`}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={lang === 'zh-tw' ? '/' : `/${lang}/`}>{t('nav.home')}</HeaderLink>
			<HeaderLink href={lang === 'zh-tw' ? '/blog' : `/${lang}/blog`}>{t('nav.blog')}</HeaderLink>
            <HeaderLink href={lang === 'zh-tw' ? '/stories' : `/${lang}/stories`}>{t('nav.stories')}</HeaderLink>
			<HeaderLink href={lang === 'zh-tw' ? '/map' : `/${lang}/map`}>{t('nav.map')}</HeaderLink>
		</div>
        <div class="lang-switcher">
            <select onchange="window.location.href = this.value">
                {Object.entries(languages).map(([code, name]) => {
                    const url = code === 'zh-tw' 
                        ? currentPath 
                        : `/${code}${currentPath.startsWith('/') ? currentPath : '/' + currentPath}`;
                    return (
                        <option value={url} selected={code === lang}>
                            {name}
                        </option>
                    );
                })}
            </select>
        </div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: #1a1a2e;
		border-bottom: 2px solid var(--neon-pink);
        box-shadow: 0 0 15px rgba(255, 0, 255, 0.3);
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}

	h2 a {
		text-decoration: none;
        color: var(--neon-pink);
        text-shadow: 0 0 10px var(--neon-pink);
        text-transform: uppercase;
        letter-spacing: 1px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
        max-width: 1000px;
        margin: 0 auto;
        padding: 1rem;
	}
	nav a {
		padding: 0.5em;
		color: #e0e0e0;
		text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;
	}
    nav a:hover, nav a.active {
        color: var(--neon-blue);
    }
    .internal-links {
        display: flex;
        gap: 10px;
    }
    .lang-switcher select {
        background: #0a0a0c;
        color: #e0e0e0;
        border: 1px solid #444;
        padding: 2px 5px;
        border-radius: 4px;
        font-size: 0.8rem;
    }
	@media (max-width: 600px) {
        nav {
            padding: 0.8rem;
            flex-wrap: wrap;
            gap: 10px;
        }
        .internal-links {
            order: 2;
            width: 100%;
            justify-content: center;
        }
        .lang-switcher {
            order: 1;
        }
	}
</style>
