---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首頁</HeaderLink>
			<HeaderLink href="/blog">攻略</HeaderLink>
			<HeaderLink href="/map">地圖</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: #1a1a2e;
		border-bottom: 2px solid var(--neon-pink);
        box-shadow: 0 0 15px rgba(255, 0, 255, 0.3);
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}

	h2 a {
		text-decoration: none;
        color: var(--neon-pink);
        text-shadow: 0 0 10px var(--neon-pink);
        text-transform: uppercase;
        letter-spacing: 1px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
        max-width: 1000px;
        margin: 0 auto;
        padding: 1rem;
	}
	nav a {
		padding: 0.5em;
		color: #e0e0e0;
		text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;
	}
    nav a:hover, nav a.active {
        color: var(--neon-blue);
    }
    .internal-links {
        display: flex;
        gap: 10px;
    }
	@media (max-width: 600px) {
        nav {
            padding: 0.8rem;
        }
        h2 {
            font-size: 1.1em;
        }
        nav a {
            font-size: 0.9rem;
            padding: 0.3em;
        }
	}
</style>
