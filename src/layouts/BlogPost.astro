---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} image={heroImage} pubDate={pubDate} />
		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: auto;
				padding: 0 0 4rem 0;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
			}
			.prose {
				width: 100%;
				max-width: 800px;
				margin: auto;
				padding: 1rem;
			}
			.title {
				margin-bottom: 2em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--gray);
			}
            
            .comment-section {
                margin-top: 5rem;
                padding-top: 2rem;
                border-top: 1px solid #333;
            }

            .comment-section h3 {
                color: var(--neon-pink);
                margin-bottom: 2rem;
            }

			@media (max-width: 720px) {
				.title h1 {
					font-size: 1.8rem;
				}
                .comment-section {
                    margin-top: 3rem;
                }
			}
		</style>
	</head>

	<body style="background-color: #0a0a0c; color: #e0e0e0; margin: 0;">
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={typeof heroImage === 'string' ? heroImage : heroImage.src} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
						</div>
						<h1 style="color: var(--neon-blue);">{title}</h1>
						<hr style="border: none; border-top: 1px solid #333;" />
					</div>
					<slot />

                    <!-- Simplified Comment Section inside .prose for better alignment -->
                    <div class="comment-section">
                        <h3>💬 討論區</h3>
                        <div id="cusdis_thread"
                            data-host="https://cusdis.com"
                            data-app-id="77aeb03e-4803-4df8-99d4-527051ac70a5"
                            data-page-id={Astro.url.pathname}
                            data-page-url={Astro.url.href}
                            data-page-title={title}
                            data-theme="dark"
                            style="min-height: 200px; width: 100%;"
                        ></div>
                        <script is:inline async defer src="https://cusdis.com/js/cusdis.es.js"></script>
                    </div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
