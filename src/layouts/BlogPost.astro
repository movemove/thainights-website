---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0 0 10rem 0; /* 大幅增加底部內邊距，確保不被截斷 */
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 0;
				width: 100%;
				max-width: 1020px;
			}
			.prose {
				width: 100%;
				max-width: 800px;
				margin: auto;
				padding: 1rem;
			}
			.title {
				margin-bottom: 2em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--gray);
			}
            .comment-wrapper {
                margin-top: 10rem; /* 大幅增加上方間距 */
                border-top: 1px solid #333;
                padding: 5rem 1rem; /* 增加內部上下間距 */
                width: 100%;
                max-width: 800px;
                margin-left: auto;
                margin-right: auto;
            }
			@media (max-width: 720px) {
				.hero-image {
					margin-bottom: 1rem;
				}
				.title {
					margin-bottom: 1rem;
				}
				.title h1 {
					font-size: 1.8rem;
				}
                .comment-wrapper {
                    margin-top: 6rem;
                    padding: 4rem 1rem;
                }
			}
		</style>
	</head>

	<body style="background-color: #0a0a0c; color: #e0e0e0;">
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
						</div>
						<h1 style="color: var(--neon-blue);">{title}</h1>
						<hr style="border: none; border-top: 1px solid #333;" />
					</div>
					<slot />
				</div>

                <!-- Move comment section OUTSIDE of .prose for full width/freedom -->
                <div class="comment-wrapper">
                    <h3 style="color: var(--neon-pink); text-align: center; margin-bottom: 1rem; font-size: 2rem;">💬 討論區</h3>
                    <p style="font-size: 1rem; color: #888; text-align: center; margin-bottom: 4rem;">免登入匿名留言，填寫暱稱即可。內容審核後顯示。</p>
                    <div id="cusdis_thread"
                        data-host="https://cusdis.com"
                        data-app-id="77aeb03e-4803-4df8-99d4-527051ac70a5"
                        data-page-id={Astro.url.pathname}
                        data-page-url={Astro.url.href}
                        data-page-title={title}
                        data-theme="dark"
                    ></div>
                    <script is:inline async defer src="https://cusdis.com/js/cusdis.es.js"></script>
                </div>
			</article>
		</main>
		<Footer />
	</body>
</html>
