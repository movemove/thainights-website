---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				max-width: 1020px;
			}
			.prose {
				width: 100%;
				max-width: 800px;
				margin: auto;
				padding: 1rem;
                flex: 1;
			}
			.title {
				margin-bottom: 2em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--gray);
			}
            
            /* Enhanced Comment Section */
            .discussion-area {
                background: #111114; /* Slightly different dark for separation */
                width: 100%;
                margin-top: 15rem; /* Massive top gap as requested */
                padding: 8rem 0; /* Massive vertical padding */
                border-top: 2px solid #222;
            }

            .comment-container {
                max-width: 800px;
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .discussion-header {
                text-align: center;
                margin-bottom: 4rem;
            }

            .discussion-header h3 {
                color: var(--neon-pink);
                font-size: 2.5rem;
                margin-bottom: 1rem;
            }

            .discussion-header p {
                color: #888;
                font-size: 1.1rem;
            }

			@media (max-width: 720px) {
				.hero-image {
					margin-bottom: 1rem;
				}
				.title {
					margin-bottom: 1rem;
				}
				.title h1 {
					font-size: 1.8rem;
				}
                .discussion-area {
                    margin-top: 10rem;
                    padding: 5rem 0;
                }
                .discussion-header h3 {
                    font-size: 2rem;
                }
			}
		</style>
	</head>

	<body style="background-color: #0a0a0c; color: #e0e0e0; margin: 0; padding: 0;">
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
						</div>
						<h1 style="color: var(--neon-blue);">{title}</h1>
						<hr style="border: none; border-top: 1px solid #333;" />
					</div>
					<slot />
				</div>
			</article>

            <!-- New Full-Width Discussion Section -->
            <section class="discussion-area">
                <div class="comment-container">
                    <div class="discussion-header">
                        <h3>💬 討論區</h3>
                        <p>免登入匿名留言，填寫暱稱即可。內容審核後顯示。</p>
                    </div>
                    
                    <div id="cusdis_thread"
                        data-host="https://cusdis.com"
                        data-app-id="77aeb03e-4803-4df8-99d4-527051ac70a5"
                        data-page-id={Astro.url.pathname}
                        data-page-url={Astro.url.href}
                        data-page-title={title}
                        data-theme="dark"
                    ></div>
                    <script is:inline async defer src="https://cusdis.com/js/cusdis.es.js"></script>
                </div>
            </section>
		</main>
		<Footer />
	</body>
</html>
